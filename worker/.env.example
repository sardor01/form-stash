# Copy this file to `worker/.env` and fill in real values. The .env file is
# gitignored. Used by scripts/render-wrangler.mjs to produce wrangler.toml.

# Cloudflare KV namespace that backs sync. Create one with:
#   pnpm wrangler kv namespace create form-stash-sync
# and paste the printed id here.
KV_NAMESPACE_ID=

# Optional: only used to write a local .dev.vars for `pnpm wrangler dev`.
# In production, set it with `pnpm wrangler secret put GOOGLE_CLIENT_ID`.
GOOGLE_CLIENT_ID=
